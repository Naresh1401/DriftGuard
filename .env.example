# DriftGuard Environment Configuration
# Copy to .env and fill in values

# ── Application ──────────────────────────────────────
APP_NAME=DriftGuard
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
API_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://driftguard:driftguard@db:5432/driftguard
# For local dev with SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./driftguard.db

# ── Vector Database ──────────────────────────────────
VECTOR_DB_TYPE=faiss
# VECTOR_DB_TYPE=qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
FAISS_INDEX_PATH=./data/faiss_index

# ── AI / ML ──────────────────────────────────────────
OPENAI_API_KEY=
NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-base
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CONFIDENCE_THRESHOLD=0.70

# ── Authentication ───────────────────────────────────
AUTH_PROVIDER=local
# AUTH_PROVIDER=okta
# AUTH_PROVIDER=azure_ad
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Data Retention ───────────────────────────────────
DATA_RETENTION_DAYS=90
DATA_RETENTION_MAX_DAYS=180

# ── Notifications ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# ── Monitoring ───────────────────────────────────────
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ── Integrations ─────────────────────────────────────
SPLUNK_HOST=
SPLUNK_TOKEN=
SENTINEL_WORKSPACE_ID=
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_TENANT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
GOOGLE_WORKSPACE_CREDENTIALS_PATH=
EPIC_EMR_BASE_URL=
EPIC_EMR_CLIENT_ID=
EPIC_EMR_PRIVATE_KEY_PATH=
